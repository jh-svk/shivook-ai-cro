generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id                   String           @id @default(uuid())
  shopifyDomain        String           @unique
  accessToken          String
  maxConcurrentTests   Int              @default(5)
  requireHumanApproval Boolean          @default(false)
  brandGuardrails      Json?
  slackWebhookUrl      String?
  installedAt          DateTime         @default(now())
  timezone             String           @default("UTC")
  experiments          Experiment[]
  dataSources          DataSource[]
  researchReports      ResearchReport[]
  hypotheses           Hypothesis[]
  knowledgeBase        KnowledgeBase[]

  @@map("shops")
}

model Experiment {
  id             String         @id @default(uuid())
  shopId         String
  name           String
  hypothesis     String
  pageType       String
  elementType    String
  targetMetric   String
  status         String         @default("draft")
  trafficSplit   Float          @default(0.5)
  minRuntimeDays Int            @default(7)
  maxRuntimeDays Int            @default(28)
  startedAt      DateTime?
  concludedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  shop           Shop           @relation(fields: [shopId], references: [id])
  variants       Variant[]
  events         Event[]
  result         Result?
  knowledgeBase  KnowledgeBase?
  hypotheses     Hypothesis[]

  @@index([shopId])
  @@map("experiments")
}

model Variant {
  id                   String     @id @default(uuid())
  experimentId         String
  type                 String
  name                 String
  description          String
  htmlPatch            String?
  cssPatch             String?
  jsPatch              String?
  themeExtensionHandle String?
  createdAt            DateTime   @default(now())
  experiment           Experiment @relation(fields: [experimentId], references: [id])
  events               Event[]

  @@map("variants")
}

model Event {
  id            String     @id @default(uuid())
  experimentId  String
  variantId     String
  visitorId     String
  sessionId     String
  eventType     String
  revenue       Float?
  checkoutToken String?
  occurredAt    DateTime   @default(now())
  experiment    Experiment @relation(fields: [experimentId], references: [id])
  variant       Variant    @relation(fields: [variantId], references: [id])

  @@index([experimentId])
  @@index([occurredAt])
  @@index([visitorId])
  @@map("events")
}

model Result {
  id                      String     @id @default(uuid())
  experimentId            String     @unique
  computedAt              DateTime
  controlVisitors         Int        @default(0)
  treatmentVisitors       Int        @default(0)
  controlConversions      Int        @default(0)
  treatmentConversions    Int        @default(0)
  controlRevenue          Float      @default(0)
  treatmentRevenue        Float      @default(0)
  controlConversionRate   Float      @default(0)
  treatmentConversionRate Float      @default(0)
  relativeLift            Float?
  pValue                  Float?
  probToBeatControl       Float?
  isSignificant           Boolean    @default(false)
  guardrailStatus         String     @default("ok")
  decision                String?
  decisionMadeAt          DateTime?
  experiment              Experiment @relation(fields: [experimentId], references: [id])

  @@map("results")
}

// ── Phase 2 tables ──────────────────────────────────────────────────────────

model DataSource {
  id           String    @id @default(uuid())
  shopId       String
  type         String    // ga4 | shopify_admin
  config       Json      // property IDs, credentials ref, etc.
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  shop         Shop      @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@map("data_sources")
}

model ResearchReport {
  id           String       @id @default(uuid())
  shopId       String
  generatedAt  DateTime     @default(now())
  dataSnapshot Json         // assembled metrics from connectors
  reportMd     String       // Claude's friction-point analysis (markdown)
  status       String       @default("pending") // pending | complete | failed
  shop         Shop         @relation(fields: [shopId], references: [id])
  hypotheses   Hypothesis[]

  @@index([shopId])
  @@map("research_reports")
}

model Hypothesis {
  id                   String          @id @default(uuid())
  shopId               String
  reportId             String?
  title                String
  hypothesis           String
  pageType             String
  elementType          String
  targetMetric         String
  iceImpact            Int             // 1-10
  iceConfidence        Int             // 1-10
  iceEase              Int             // 1-10
  iceScore             Float           // impact * confidence * ease
  status               String          @default("backlog") // backlog | promoted | rejected
  promotedExperimentId String?
  createdAt            DateTime        @default(now())
  shop                 Shop            @relation(fields: [shopId], references: [id])
  report               ResearchReport? @relation(fields: [reportId], references: [id])
  promotedExperiment   Experiment?     @relation(fields: [promotedExperimentId], references: [id])

  @@index([shopId])
  @@index([iceScore])
  @@map("hypotheses")
}

model KnowledgeBase {
  id                 String     @id @default(uuid())
  shopId             String
  experimentId       String     @unique
  hypothesisText     String
  segmentTargeted    String?
  variantDescription String
  result             String     // win | loss | inconclusive
  liftPercentage     Float?
  pageType           String
  elementType        String
  tags               String[]
  embedding          Unsupported("vector(1536)")?
  createdAt          DateTime   @default(now())
  shop               Shop       @relation(fields: [shopId], references: [id])
  experiment         Experiment @relation(fields: [experimentId], references: [id])

  @@index([shopId])
  @@map("knowledge_base")
}
