generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id                   String       @id @default(uuid())
  shopifyDomain        String       @unique
  accessToken          String
  maxConcurrentTests   Int          @default(5)
  requireHumanApproval Boolean      @default(false)
  brandGuardrails      Json?
  slackWebhookUrl      String?
  installedAt          DateTime     @default(now())
  timezone             String       @default("UTC")
  experiments          Experiment[]

  @@map("shops")
}

model Experiment {
  id             String     @id @default(uuid())
  shopId         String
  name           String
  hypothesis     String
  pageType       String
  elementType    String
  targetMetric   String
  status         String     @default("draft")
  trafficSplit   Float      @default(0.5)
  minRuntimeDays Int        @default(7)
  maxRuntimeDays Int        @default(28)
  startedAt      DateTime?
  concludedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  shop           Shop       @relation(fields: [shopId], references: [id])
  variants       Variant[]
  events         Event[]
  result         Result?

  @@index([shopId])
  @@map("experiments")
}

model Variant {
  id                   String     @id @default(uuid())
  experimentId         String
  type                 String
  name                 String
  description          String
  htmlPatch            String?
  cssPatch             String?
  jsPatch              String?
  themeExtensionHandle String?
  createdAt            DateTime   @default(now())
  experiment           Experiment @relation(fields: [experimentId], references: [id])
  events               Event[]

  @@map("variants")
}

model Event {
  id             String     @id @default(uuid())
  experimentId   String
  variantId      String
  visitorId      String
  sessionId      String
  eventType      String
  revenue        Float?
  checkoutToken  String?
  occurredAt     DateTime   @default(now())
  experiment     Experiment @relation(fields: [experimentId], references: [id])
  variant        Variant    @relation(fields: [variantId], references: [id])

  @@index([experimentId])
  @@index([occurredAt])
  @@index([visitorId])
  @@map("events")
}

model Result {
  id                      String     @id @default(uuid())
  experimentId            String     @unique
  computedAt              DateTime
  controlVisitors         Int        @default(0)
  treatmentVisitors       Int        @default(0)
  controlConversions      Int        @default(0)
  treatmentConversions    Int        @default(0)
  controlRevenue          Float      @default(0)
  treatmentRevenue        Float      @default(0)
  controlConversionRate   Float      @default(0)
  treatmentConversionRate Float      @default(0)
  relativeLift            Float?
  pValue                  Float?
  isSignificant           Boolean    @default(false)
  guardrailStatus         String     @default("ok")
  decision                String?
  decisionMadeAt          DateTime?
  experiment              Experiment @relation(fields: [experimentId], references: [id])

  @@map("results")
}
